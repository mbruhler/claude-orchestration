# Temporary agent files (ephemeral, not committed)
temp-agents/*.md

# Temporary scripts (auto-generated)
temp-scripts/*

# Workflow files with sensitive credentials
examples/reddit-plugin-promotion.flow

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Node modules (if any testing infrastructure)
node_modules/

# Python cache (if any Python scripts)
__pycache__/
*.pyc
*.pyo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.local

# API credentials - NEVER commit these
config/*-credentials.json
config/credentials*.json
**/credentials.json
**/secrets.json
*.credentials.json

# Campaign data (may contain sensitive info)
campaigns/
